# Azure AI Foundry configuration
# Copy this file to config.env and fill in your values

# The endpoint URL for your Azure AI Foundry project
# Example: https://<your-resource>.services.ai.azure.com/models
AZURE_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/models

# Your Azure AI Foundry API key
AZURE_FOUNDRY_API_KEY=your-api-key-here

# The model deployment name to use
# Example: gpt-4o, Phi-4, Meta-Llama-3-8B-Instruct
AZURE_FOUNDRY_MODEL=your-model-deployment-name

# Optional: system prompt to set assistant behavior
SYSTEM_PROMPT=You are a helpful assistant.
