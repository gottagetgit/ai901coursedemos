# Azure AI Foundry Agent configuration
# Copy this file to config.env and fill in your values

# Your Azure AI Foundry project endpoint
# Found under: your project > Settings > Project details > Endpoint
AZURE_FOUNDRY_ENDPOINT=https://your-project.api.azureml.ms

# Your Azure AI Foundry API key
AZURE_FOUNDRY_API_KEY=your_key

# The name of the agent as it appears in the Foundry portal
AZURE_FOUNDRY_AGENT_NAME=ai901agent

# The version label for display purposes
AZURE_FOUNDRY_AGENT_VERSION=v2
