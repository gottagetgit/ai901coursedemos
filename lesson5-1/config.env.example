# Azure AI Language (Text Analytics) configuration
# Copy this file to config.env and fill in your values

# The endpoint URL for your Azure AI Language resource
# Found in the Azure portal under your Language resource > Keys and Endpoint
# Example: https://your-resource.cognitiveservices.azure.com/
AZURE_LANGUAGE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# API key for the Language resource
AZURE_LANGUAGE_KEY=your-language-key-here
