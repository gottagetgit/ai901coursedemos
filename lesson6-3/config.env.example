# Azure AI Vision configuration
# Copy this file to config.env and fill in your values

# The endpoint URL for your Azure AI Vision (Computer Vision) resource
# Found in the Azure portal under your Vision resource > Keys and Endpoint
# Example: https://your-resource.cognitiveservices.azure.com/
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# API key for the Vision resource
AZURE_VISION_KEY=your-vision-key-here
