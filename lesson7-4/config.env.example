# Azure AI Content Understanding configuration
# Copy this file to config.env and fill in your values

# The endpoint URL for your Azure AI Foundry / AI Services resource that has
# Content Understanding enabled.
# Found in the Azure portal under your resource > Keys and Endpoint
# Example: https://your-resource.cognitiveservices.azure.com/
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# API key for the resource
AZURE_CONTENT_UNDERSTANDING_KEY=your-content-understanding-key-here
